---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.published);
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('id-ID', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog Peternakan Domba - Tips & Panduan"
  description="Artikel dan panduan seputar peternakan domba, kemitraan ternak, tips qurban, aqiqah, dan inovasi peternakan berkelanjutan."
  lang="id"
>
  <!-- Hero Banner -->
  <section class="relative flex h-[40vh] items-center justify-center bg-gradient-to-br from-primary to-secondary text-offwhite">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl mb-4">Blog & Artikel</h1>
      <p class="font-body text-lg md:text-xl text-offwhite/80 max-w-2xl mx-auto">
        Tips, panduan, dan informasi terkini seputar peternakan domba, kemitraan ternak, dan inovasi agribisnis berkelanjutan.
      </p>
    </div>
  </section>

  <!-- Article Grid -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid gap-8 md:grid-cols-2">
        {sorted.map((post, index) => (
          <ScrollReveal delay={index * 100}>
            <a href={`/blog/${post.id}`} class="group block rounded-2xl bg-offwhite shadow-sm hover:shadow-md transition-shadow p-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs font-body text-primary font-semibold uppercase tracking-wide">{post.data.category}</span>
                <span class="text-xs text-secondary/40">|</span>
                <span class="text-xs font-body text-secondary/50">{formatDate(post.data.date)}</span>
                <span class="text-xs text-secondary/40">|</span>
                <span class="text-xs font-body text-secondary/50">{post.data.read_time} baca</span>
              </div>
              <h2 class="font-heading text-xl md:text-2xl text-secondary group-hover:text-primary transition-colors mb-3">
                {post.data.title_id}
              </h2>
              <p class="font-body text-sm text-secondary/70 leading-relaxed line-clamp-3 mb-4">
                {post.data.excerpt_id}
              </p>
              <span class="inline-flex items-center gap-1 font-body text-sm font-medium text-primary group-hover:gap-2 transition-all">
                Baca Selengkapnya
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();
</script>
