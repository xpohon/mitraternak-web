---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import Button from '@/components/ui/Button.astro';

export function getStaticPaths() {
  return [
    {
      params: { slug: 'bisa-qurban' },
      props: {
        product: {
          name: 'BISA Qurban',
          tagline: 'Solusi qurban transparan & berkualitas',
          description: 'Program BISA Qurban menyediakan domba qurban berkualitas tinggi dengan sistem timbangan digital yang menjamin transparansi harga dan berat. Setiap domba dipelihara oleh peternak mitra kami dengan standar kesehatan dan kesejahteraan hewan yang tinggi.',
          features: [
            'Domba qurban dengan sertifikat kesehatan',
            'Timbangan digital untuk transparansi berat',
            'Harga yang adil dan kompetitif',
            'Pengiriman tepat waktu untuk hari raya',
            'Pendampingan proses penyembelihan sesuai syariat',
          ],
        },
      },
    },
    {
      params: { slug: 'mitra-bhakti-aqiqah' },
      props: {
        product: {
          name: 'Mitra Bhakti Aqiqah',
          tagline: 'Layanan aqiqah terpercaya dari peternak lokal',
          description: 'Mitra Bhakti Aqiqah adalah layanan aqiqah terintegrasi yang menghubungkan keluarga dengan peternak lokal. Kami memastikan setiap domba memenuhi syarat aqiqah dengan kualitas terbaik dan harga yang transparan.',
          features: [
            'Domba pilihan sesuai syarat aqiqah',
            'Paket lengkap termasuk penyembelihan & distribusi',
            'Dokumentasi lengkap untuk keluarga',
            'Kerjasama dengan ustadz lokal',
            'Mendukung ekonomi peternak lokal',
          ],
        },
      },
    },
    {
      params: { slug: 'kemitraan-titip-ternak' },
      props: {
        product: {
          name: 'Kemitraan Titip Ternak',
          tagline: 'Jadi Pemilik Domba Tanpa Harus Turun ke Kandang',
          description: 'Program kemitraan titip ternak pembibitan domba memungkinkan Anda berinvestasi di peternakan domba tanpa harus memiliki lahan, kandang, atau pengalaman beternak. Mitra akan mendapatkan hasil panen anakan hingga 3 kali selama 24 bulan dengan keuntungan hingga 61% per siklus. Semua proses dikelola secara profesional oleh PT Mitra Ternak Berkelanjutan.',
          features: [
            'Anda pemilik domba yang sah sepenuhnya',
            'Semua proses kemitraan tertuang pada Surat Perjanjian Kerjasama (SPK)',
            'Mendapatkan KTP domba dan akses CCTV 24 jam',
            'Tergabung program asuransi kematian ternak',
            'Kepastian harga jual panen anakan sesuai kontrak',
            'Gratis biaya sewa kandang dan tenaga kerja',
            'Gratis jasa kawin dengan pejantan super',
            'Gratis biaya kesehatan dan operasional ternak',
            'Keuntungan hingga 61% per siklus (durasi 24 bulan)',
            'Laporan berkala dan monitoring via CCTV',
          ],
          packages: [
            {
              name: 'Paket Eksekutif',
              desc: '3 ekor domba betina indukan',
              perks: ['Gratis jasa kawin pejantan super', 'Gratis biaya pakan 4 bulan'],
              roi: '42%',
            },
            {
              name: 'Paket Platinum',
              desc: '9 ekor domba betina indukan',
              perks: ['Gratis jasa kawin pejantan super', 'Gratis biaya pakan 5 bulan'],
              roi: '49%',
            },
            {
              name: 'Paket Juragan',
              desc: '15 ekor domba betina indukan',
              perks: ['Gratis jasa kawin pejantan super', 'Gratis biaya pakan 6 bulan'],
              roi: '61%',
            },
          ],
          steps: [
            { title: 'Pilih Paket Kemitraan', desc: 'Tentukan domba indukan sesuai yang Anda sukai' },
            { title: 'Pelunasan Pembayaran', desc: 'Anda secara resmi telah memiliki domba indukan yang akan diproses pada program kemitraan' },
            { title: 'Pengiriman SPK', desc: 'Kami akan mengirimkan Surat Perjanjian Kerjasama kemitraan ke alamat Anda' },
            { title: 'Akses Data & CCTV', desc: 'Anda akan mendapatkan akses domba secara digital dan dapat memantau langsung melalui CCTV' },
          ],
        },
      },
    },
  ];
}

const { product } = Astro.props;
---

<BaseLayout title={product.name} description={product.tagline} lang="id">
  <!-- Hero Section -->
  <section class="relative flex min-h-[50vh] items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary/90 to-secondary/80"></div>
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(circle at 30% 40%, rgba(212,168,83,0.4) 0%, transparent 50%), radial-gradient(circle at 70% 60%, rgba(74,124,89,0.4) 0%, transparent 50%);"
      ></div>
    </div>
    <div class="relative z-10 px-4 text-center">
      <ScrollReveal>
        <span class="mb-4 inline-block rounded-full bg-offwhite/20 px-4 py-1 text-sm font-body text-offwhite">Produk Kami</span>
        <h1 class="font-heading text-4xl leading-tight text-offwhite md:text-5xl lg:text-6xl">{product.name}</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg font-body text-offwhite/80">{product.tagline}</p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Description -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4">
      <ScrollReveal>
        <div class="rounded-2xl bg-neutral p-8 md:p-12">
          <h2 class="mb-6 font-heading text-3xl text-secondary">Tentang {product.name}</h2>
          <p class="font-body text-lg leading-relaxed text-secondary/70">{product.description}</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-offwhite py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4">
      <ScrollReveal>
        <h2 class="mb-12 text-center font-heading text-3xl text-secondary">Keunggulan & Manfaat</h2>
      </ScrollReveal>
      <div class="space-y-4">
        {product.features.map((feature: string, index: number) => (
          <ScrollReveal delay={index * 100}>
            <div class="flex items-start gap-4 rounded-xl bg-white p-6 shadow-sm">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-offwhite">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <p class="font-body text-lg text-secondary/80">{feature}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Packages (only for kemitraan-titip-ternak) -->
  {product.packages && (
    <section class="bg-neutral py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-4">
        <ScrollReveal>
          <h2 class="mb-4 text-center font-heading text-3xl text-secondary">Paket Kemitraan</h2>
          <p class="mb-12 text-center font-body text-secondary/70">Beli sekali, panennya hingga 3 kali</p>
        </ScrollReveal>
        <div class="grid gap-8 md:grid-cols-3">
          {product.packages.map((pkg: any, i: number) => (
            <ScrollReveal delay={i * 150}>
              <div class={`relative overflow-hidden rounded-2xl p-8 shadow-md transition-all hover:-translate-y-1 hover:shadow-lg ${i === 2 ? 'bg-secondary text-offwhite' : 'bg-offwhite text-secondary'}`}>
                {i === 2 && (
                  <span class="absolute right-4 top-4 rounded-full bg-warm px-3 py-1 text-xs font-bold text-secondary">POPULER</span>
                )}
                <h3 class="font-heading text-2xl">{pkg.name}</h3>
                <p class={`mt-2 text-sm font-body ${i === 2 ? 'text-offwhite/70' : 'text-secondary/60'}`}>{pkg.desc}</p>
                <div class="my-6">
                  <span class="text-4xl font-bold font-body text-primary">ROI {pkg.roi}</span>
                </div>
                <ul class="space-y-3">
                  {pkg.perks.map((perk: string) => (
                    <li class={`flex items-start gap-2 text-sm font-body ${i === 2 ? 'text-offwhite/80' : 'text-secondary/70'}`}>
                      <span class="mt-0.5 text-accent">✓</span>
                      {perk}
                    </li>
                  ))}
                </ul>
                <Button
                  href="https://wa.me/6285792671147"
                  target="_blank"
                  variant={i === 2 ? 'primary' : 'outline'}
                  size="md"
                  class="mt-8 w-full text-center"
                >
                  Pilih Paket
                </Button>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Steps (only for kemitraan-titip-ternak) -->
  {product.steps && (
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-4xl px-4">
        <ScrollReveal>
          <h2 class="mb-12 text-center font-heading text-3xl text-secondary">Bagaimana Proses Bergabung?</h2>
        </ScrollReveal>
        <div class="space-y-6">
          {product.steps.map((step: any, i: number) => (
            <ScrollReveal delay={i * 100}>
              <div class="flex items-start gap-6 rounded-xl bg-neutral p-6">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary text-xl font-bold text-offwhite font-body">
                  {i + 1}
                </div>
                <div>
                  <h3 class="font-heading text-xl text-secondary">{step.title}</h3>
                  <p class="mt-1 font-body text-secondary/70">{step.desc}</p>
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 md:py-24" style="background: linear-gradient(135deg, #8B6914 0%, #2C1810 100%);">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <ScrollReveal>
        <h2 class="mb-4 font-heading text-3xl text-offwhite">Tertarik dengan {product.name}?</h2>
        <p class="mb-8 font-body text-lg text-offwhite/80">Hubungi kami via WhatsApp untuk informasi lebih lanjut dan pemesanan.</p>
        <Button
          href="https://wa.me/6285792671147"
          target="_blank"
          variant="secondary"
          size="lg"
        >
          Hubungi via WhatsApp
        </Button>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();
</script>
