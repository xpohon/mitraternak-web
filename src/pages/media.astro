---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import { useTranslations } from '@/i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'id';
const t = useTranslations(lang);

const mediaCollection = await getCollection('media', ({ data }) => data.published);
const mediaItems = mediaCollection
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((item) => ({
    type: item.data.type === 'video' ? 'video' : 'berita',
    title: item.data.title_id,
    summary: item.data.summary_id,
    source: item.data.source,
    date: new Date(item.data.date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }),
    thumbnail: item.data.thumbnail,
    url: item.data.url,
  }));
---

<PageLayout
  title="Liputan Media Mitra Ternak Farm Tuban"
  description="Berita dan liputan media tentang Mitra Ternak Farm Tuban. Diliput tvOne, iNews, CNN Indonesia, dan media nasional lainnya."
  heroTitle={t('mediapage.title')}
  heroSubtitle={t('mediapage.subtitle')}
>
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4">
      <!-- Tab Filters -->
      <div class="mb-12 flex flex-wrap justify-center gap-3">
        <button
          class="media-tab active rounded-full bg-primary px-6 py-2 font-body font-medium text-offwhite transition-colors"
          data-filter="semua"
        >
          Semua
        </button>
        <button
          class="media-tab rounded-full bg-neutral px-6 py-2 font-body font-medium text-secondary transition-colors hover:bg-primary hover:text-offwhite"
          data-filter="berita"
        >
          Berita
        </button>
        <button
          class="media-tab rounded-full bg-neutral px-6 py-2 font-body font-medium text-secondary transition-colors hover:bg-primary hover:text-offwhite"
          data-filter="video"
        >
          Video
        </button>
      </div>

      <!-- Media Grid -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" id="media-grid">
        {mediaItems.map((item, index) => (
          <ScrollReveal delay={index * 100}>
            <article class="media-card overflow-hidden rounded-2xl bg-white shadow-sm transition-shadow hover:shadow-lg" data-type={item.type}>
              <!-- Thumbnail -->
              <div class="relative h-48 overflow-hidden">
                <img src={item.thumbnail} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
                {item.type === 'video' && (
                  <div class="absolute inset-0 flex items-center justify-center bg-dark/30">
                    <div class="w-14 h-14 bg-primary/90 rounded-full flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-offwhite ml-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                )}
                <!-- Type Badge -->
                <span class:list={[
                  'absolute left-4 top-4 rounded-full px-3 py-1 text-xs font-body font-medium text-offwhite',
                  item.type === 'video' ? 'bg-accent' : 'bg-primary',
                ]}>
                  {item.type === 'video' ? 'Video' : 'Berita'}
                </span>
              </div>
              <!-- Content -->
              <div class="p-6">
                <h3 class="mb-2 font-heading text-lg text-secondary line-clamp-2">{item.title}</h3>
                <p class="mb-3 text-sm text-secondary/60 font-body line-clamp-3">{item.summary}</p>
                <div class="flex items-center justify-between text-sm font-body text-secondary/50 mb-3">
                  <span>{item.source}</span>
                  <span>{item.date}</span>
                </div>
                {item.url !== '#' && (
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-primary font-semibold hover:text-primary-dark transition-colors font-body">
                    Selengkapnya
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
                    </svg>
                  </a>
                )}
              </div>
            </article>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();

  function initMediaTabs() {
    const tabs = document.querySelectorAll('.media-tab');
    const cards = document.querySelectorAll('.media-card');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const filter = (tab as HTMLElement).dataset.filter;

        tabs.forEach((t) => {
          t.classList.remove('active', 'bg-primary', 'text-offwhite');
          t.classList.add('bg-neutral', 'text-secondary');
        });
        tab.classList.add('active', 'bg-primary', 'text-offwhite');
        tab.classList.remove('bg-neutral', 'text-secondary');

        cards.forEach((card) => {
          const type = (card as HTMLElement).dataset.type;
          const wrapper = card.closest('[data-scroll-reveal]') as HTMLElement;
          if (filter === 'semua' || type === filter) {
            if (wrapper) wrapper.style.display = '';
          } else {
            if (wrapper) wrapper.style.display = 'none';
          }
        });
      });
    });
  }

  initMediaTabs();
  document.addEventListener('astro:after-swap', initMediaTabs);
</script>
