---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import Button from '@/components/ui/Button.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<PageLayout
  title={t('contact.title')}
  description={t('contact.subtitle')}
  heroTitle={t('contact.title')}
  heroSubtitle={t('contact.subtitle')}
>
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Contact Form -->
        <ScrollReveal direction="left">
          <div class="rounded-2xl bg-white p-8 shadow-sm">
            <h2 class="mb-6 font-heading text-2xl text-secondary">Send a Message</h2>
            <form action="#" method="POST" class="space-y-6">
              <div>
                <label for="name" class="mb-2 block font-body text-sm font-medium text-secondary">
                  {t('contact.form.name')}
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-neutral bg-offwhite px-4 py-3 font-body text-secondary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="Enter your full name"
                />
              </div>
              <div>
                <label for="email" class="mb-2 block font-body text-sm font-medium text-secondary">
                  {t('contact.form.email')}
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-lg border border-neutral bg-offwhite px-4 py-3 font-body text-secondary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="email@example.com"
                />
              </div>
              <div>
                <label for="phone" class="mb-2 block font-body text-sm font-medium text-secondary">
                  {t('contact.form.phone')}
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full rounded-lg border border-neutral bg-offwhite px-4 py-3 font-body text-secondary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="+62 xxx-xxxx-xxxx"
                />
              </div>
              <div>
                <label for="message" class="mb-2 block font-body text-sm font-medium text-secondary">
                  {t('contact.form.message')}
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full rounded-lg border border-neutral bg-offwhite px-4 py-3 font-body text-secondary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-none"
                  placeholder="Write your message..."
                ></textarea>
              </div>
              <Button variant="primary" size="lg" class="w-full">
                {t('contact.form.submit')}
              </Button>
            </form>
          </div>
        </ScrollReveal>

        <!-- Contact Info -->
        <ScrollReveal direction="right">
          <div class="space-y-6">
            <!-- WhatsApp -->
            <div class="flex items-start gap-4 rounded-2xl bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-green-100">
                <svg class="h-6 w-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg text-secondary">WhatsApp</h3>
                <p class="mt-1 font-body text-secondary/70">+62 812-3456-7890</p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4 rounded-2xl bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary/10">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg text-secondary">Email</h3>
                <p class="mt-1 font-body text-secondary/70">info@mitraternak.co.id</p>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4 rounded-2xl bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-warm/10">
                <svg class="h-6 w-6 text-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg text-secondary">Location</h3>
                <p class="mt-1 font-body text-secondary/70">{t('footer.location')}</p>
              </div>
            </div>

            <!-- Google Maps Placeholder -->
            <div class="flex h-64 items-center justify-center rounded-2xl bg-neutral">
              <div class="text-center">
                <svg class="mx-auto h-12 w-12 text-secondary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                </svg>
                <p class="mt-2 font-body text-secondary/50">Google Maps</p>
              </div>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();
</script>
