---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import Button from '@/components/ui/Button.astro';

export function getStaticPaths() {
  return [
    {
      params: { slug: 'bisa-qurban' },
      props: {
        product: {
          name: 'Bisa Qurban',
          tagline: 'Fulfill Your Intention, Spread the Benefit — Starting from IDR 50,000',
          description: 'Bisa Qurban was born from a determination to make qurban worship easier while creating real impact. We believe that qurban is not just a ritual, but a way to bring widespread benefits — for you as the sacrificer and for those in need. Bisa Qurban is a flagship program from PT Mitra Ternak Berkelanjutan that connects sacrificers directly with local farmers for affordable and transparent pricing.',
          features: [
            'Affordable prices directly from local farmers',
            'Healthy livestock with health checks for qurban eligibility',
            'Flexible payment: installments or full with animal death guarantee',
            'Distribution of qurban meat to villages in need',
            'Visit Farm — buyers can come directly to choose livestock',
            'Complete documentation of the qurban process',
            'Slaughter in accordance with Islamic law',
            'Partnered with hundreds of local farmers',
          ],
          steps: [
            { title: 'Choose Qurban Animal', desc: 'Various qurban animal options to suit your needs and budget' },
            { title: 'Payment (Installment/Full)', desc: 'Choose full or installment payment with animal death guarantee' },
            { title: 'Sharia-Compliant Slaughter', desc: 'Qurban animals are slaughtered according to Islamic law with complete documentation' },
            { title: 'Meat Distribution', desc: 'Qurban meat is distributed to villages in need for equitable benefit' },
          ],
        },
      },
    },
    {
      params: { slug: 'mitra-bhakti-aqiqah' },
      props: {
        product: {
          name: 'Mitra Bhakti Aqiqah',
          tagline: 'Hassle-Free Aqiqah Service — Starting from IDR 2 Million',
          description: 'Mitra Bhakti Aqiqah provides aqiqah services with quality sheep raised and managed by professional staff at our own farm. Each sheep is cared for by experienced team members, monitored daily for health, and given nutritious feed. The entire process from animal selection, sharia-compliant slaughter, menu preparation, to delivery is carried out with high hygiene and professionalism standards.',
          features: [
            'Sheep from our own farm, health-monitored daily',
            'Slaughter in accordance with Islamic law',
            'Hygienic cooked dishes ready to serve',
            'Official aqiqah certificate',
            'Photo and video documentation of slaughter process',
            'Neat packaging and delivery to your address',
            'Supported by local farmers and professional team',
            'Affordable prices starting from IDR 2 million',
          ],
          packages: [
            {
              name: 'Girl Package',
              desc: '1 sheep',
              perks: ['Sharia-compliant slaughter', 'Hygienic cooked dishes & ready to serve', 'Aqiqah certificate'],
              roi: '2M IDR',
            },
            {
              name: 'Boy Package',
              desc: '2 sheep',
              perks: ['Sharia-compliant slaughter', 'Complete & hygienic cooked dishes', 'Aqiqah certificate', 'Photo documentation', 'Neat packaging'],
              roi: '3M IDR',
            },
            {
              name: 'Premium Package',
              desc: 'Premium quality selected sheep',
              perks: ['Sharia-compliant slaughter', 'Complete menu & ready to serve', 'Aqiqah certificate', 'Photo & video documentation', 'Free delivery'],
              roi: '5.5M IDR',
            },
          ],
          steps: [
            { title: 'Choose Package', desc: 'Select an aqiqah package that suits your needs' },
            { title: 'Order Confirmation', desc: 'Our team helps with the process and scheduling' },
            { title: 'Aqiqah Process', desc: 'Carried out according to sharia with documentation' },
            { title: 'Delivery', desc: 'Order is ready to be delivered to your address' },
          ],
        },
      },
    },
    {
      params: { slug: 'kemitraan-titip-ternak' },
      props: {
        product: {
          name: 'Livestock Partnership Program',
          tagline: 'Own Sheep Without Having to Step Into the Farm',
          description: 'The sheep breeding partnership program allows you to invest in sheep farming without owning land, a barn, or having farming experience. Partners receive up to 3 harvests of lambs within 24 months with returns up to 61% per cycle. All processes are professionally managed by PT Mitra Ternak Berkelanjutan.',
          features: [
            'You are the rightful owner of the sheep',
            'All partnership processes are documented in a Cooperation Agreement (SPK)',
            'Receive sheep ID card and 24-hour CCTV access',
            'Enrolled in livestock death insurance program',
            'Guaranteed lamb harvest selling price per contract',
            'Free barn rental and labor costs',
            'Free mating service with super sires',
            'Free health and operational costs for livestock',
            'Returns up to 61% per cycle (24-month duration)',
            'Regular reports and CCTV monitoring',
          ],
          packages: [
            {
              name: 'Executive Package',
              desc: '3 female breeding sheep',
              perks: ['Free super sire mating service', 'Free feed costs for 4 months'],
              roi: 'ROI 42%',
            },
            {
              name: 'Platinum Package',
              desc: '9 female breeding sheep',
              perks: ['Free super sire mating service', 'Free feed costs for 5 months'],
              roi: 'ROI 49%',
            },
            {
              name: 'Juragan Package',
              desc: '15 female breeding sheep',
              perks: ['Free super sire mating service', 'Free feed costs for 6 months'],
              roi: 'ROI 61%',
            },
          ],
          steps: [
            { title: 'Choose Partnership Package', desc: 'Select the breeding sheep that suit your preference' },
            { title: 'Complete Payment', desc: 'You officially own the breeding sheep to be processed in the partnership program' },
            { title: 'Receive Cooperation Agreement', desc: 'We will send the partnership cooperation agreement to your address' },
            { title: 'Access Data & CCTV', desc: 'You will receive digital sheep access and can monitor directly via CCTV' },
          ],
        },
      },
    },
  ];
}

const { product } = Astro.props;
---

<BaseLayout title={`${product.name} - Mitra Ternak Tuban`} description={product.tagline} lang="en">
  <!-- Hero Section -->
  <section class="relative flex min-h-[50vh] items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary/90 to-secondary/80"></div>
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(circle at 30% 40%, rgba(212,168,83,0.4) 0%, transparent 50%), radial-gradient(circle at 70% 60%, rgba(74,124,89,0.4) 0%, transparent 50%);"
      ></div>
    </div>
    <div class="relative z-10 px-4 text-center">
      <ScrollReveal>
        <span class="mb-4 inline-block rounded-full bg-offwhite/20 px-4 py-1 text-sm font-body text-offwhite">Our Products</span>
        <h1 class="font-heading text-4xl leading-tight text-offwhite md:text-5xl lg:text-6xl">{product.name}</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg font-body text-offwhite/80">{product.tagline}</p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Description -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4">
      <ScrollReveal>
        <div class="rounded-2xl bg-neutral p-8 md:p-12">
          <h2 class="mb-6 font-heading text-3xl text-secondary">About {product.name}</h2>
          <p class="font-body text-lg leading-relaxed text-secondary/70">{product.description}</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-offwhite py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4">
      <ScrollReveal>
        <h2 class="mb-12 text-center font-heading text-3xl text-secondary">Features & Benefits</h2>
      </ScrollReveal>
      <div class="space-y-4">
        {product.features.map((feature: string, index: number) => (
          <ScrollReveal delay={index * 100}>
            <div class="flex items-start gap-4 rounded-xl bg-white p-6 shadow-sm">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-offwhite">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <p class="font-body text-lg text-secondary/80">{feature}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Packages -->
  {product.packages && (
    <section class="bg-neutral py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-4">
        <ScrollReveal>
          <h2 class="mb-4 text-center font-heading text-3xl text-secondary">Partnership Packages</h2>
          <p class="mb-12 text-center font-body text-secondary/70">Buy once, harvest up to 3 times</p>
        </ScrollReveal>
        <div class="grid gap-8 md:grid-cols-3">
          {product.packages.map((pkg: any, i: number) => (
            <ScrollReveal delay={i * 150}>
              <div class={`relative overflow-hidden rounded-2xl p-8 shadow-md transition-all hover:-translate-y-1 hover:shadow-lg ${i === 2 ? 'bg-secondary text-offwhite' : 'bg-offwhite text-secondary'}`}>
                {i === 2 && (
                  <span class="absolute right-4 top-4 rounded-full bg-warm px-3 py-1 text-xs font-bold text-secondary">POPULAR</span>
                )}
                <h3 class="font-heading text-2xl">{pkg.name}</h3>
                <p class={`mt-2 text-sm font-body ${i === 2 ? 'text-offwhite/70' : 'text-secondary/60'}`}>{pkg.desc}</p>
                <div class="my-6">
                  <span class="text-4xl font-bold font-body text-primary">{pkg.roi}</span>
                </div>
                <ul class="space-y-3">
                  {pkg.perks.map((perk: string) => (
                    <li class={`flex items-start gap-2 text-sm font-body ${i === 2 ? 'text-offwhite/80' : 'text-secondary/70'}`}>
                      <span class="mt-0.5 text-accent">✓</span>
                      {perk}
                    </li>
                  ))}
                </ul>
                <Button href="https://wa.me/6285792671147" target="_blank" variant={i === 2 ? 'primary' : 'outline'} size="md" class="mt-8 w-full text-center">
                  Choose Package
                </Button>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Steps -->
  {product.steps && (
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-4xl px-4">
        <ScrollReveal>
          <h2 class="mb-12 text-center font-heading text-3xl text-secondary">How to Join?</h2>
        </ScrollReveal>
        <div class="space-y-6">
          {product.steps.map((step: any, i: number) => (
            <ScrollReveal delay={i * 100}>
              <div class="flex items-start gap-6 rounded-xl bg-neutral p-6">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary text-xl font-bold text-offwhite font-body">
                  {i + 1}
                </div>
                <div>
                  <h3 class="font-heading text-xl text-secondary">{step.title}</h3>
                  <p class="mt-1 font-body text-secondary/70">{step.desc}</p>
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 md:py-24" style="background: linear-gradient(135deg, #8B6914 0%, #2C1810 100%);">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <ScrollReveal>
        <h2 class="mb-4 font-heading text-3xl text-offwhite">Interested in {product.name}?</h2>
        <p class="mb-8 font-body text-lg text-offwhite/80">Contact us via WhatsApp for more information and orders.</p>
        <Button href="https://wa.me/6285792671147" target="_blank" variant="secondary" size="lg">
          Contact via WhatsApp
        </Button>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();
</script>
