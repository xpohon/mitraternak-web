---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const mediaItems = [
  {
    type: 'news',
    title: 'Mitra Ternak Farm Tuban Records Surge in Demand for Sacrificial Sheep Ahead of Eid al-Adha',
    summary: 'Ahead of Eid al-Adha, blessings are being felt by sacrificial animal farmers. One of them is in Desa Ngrayung, Kecamatan Plumpang, Tuban.',
    source: 'petisi.co',
    date: 'May 30, 2025',
    thumbnail: '/images/media/petisi.webp',
    url: 'https://petisi.co/mitra-ternak-farm-tuban-catat-lonjakan-permintaan-domba-kurban-jelang-idul-adha/',
  },
  {
    type: 'news',
    title: 'Sheep Breeding System Farmer in Tuban, Flooded with Orders Ahead of Eid al-Adha',
    summary: 'In Tuban Regency, East Java, a sheep farm implements a modern breeding system, resulting in a flood of orders ahead of Eid al-Adha.',
    source: 'iNews Tuban',
    date: 'May 31, 2025',
    thumbnail: '/images/media/inews.webp',
    url: 'https://tuban.inews.id/read/602173/peternak-domba-sistem-breeding-di-tuban-banjir-pesanan-menjelang-idul-adha',
  },
  {
    type: 'video',
    title: 'Youth in Tuban Successfully Runs Sheep Breeding Business | Kabar Siang tvOne',
    summary: 'Kabar Siang tvOneNews covers the success of millennial sheep breeders at Mitra Ternak Farm in Tuban.',
    source: 'tvOneNews (YouTube)',
    date: 'Jun 2, 2025',
    thumbnail: '/images/media/tvone.webp',
    url: 'https://youtu.be/J8UyBI6uE74',
  },
  {
    type: 'video',
    title: 'Youth in Tuban Successfully Masters Sheep Breeding Business',
    summary: 'Sketsa Bengawan JTV Bojonegoro covers the success of young sheep breeders in the Tuban and Lamongan region.',
    source: 'JTV Bojonegoro (YouTube)',
    date: 'May 30, 2025',
    thumbnail: '/images/media/jtv.webp',
    url: 'https://youtu.be/wvjwW76oN_M',
  },
  {
    type: 'news',
    title: 'Berita Jatim Coverage on Mitra Ternak Farm Tuban',
    summary: 'Berita Jatim covers the development of modern sheep farming in Tuban by Mitra Ternak Farm.',
    source: 'Berita Jatim',
    date: 'May 28, 2025',
    thumbnail: '/images/media/beritajatim.webp',
    url: '#',
  },
  {
    type: 'news',
    title: 'Mitra Ternak Farm Manages Thousands of Quality Sheep',
    summary: 'Radio Republik Indonesia covers modern sheep farming innovation and partnerships in Tuban, East Java.',
    source: 'RRI',
    date: 'May 25, 2025',
    thumbnail: '/images/media/rri.webp',
    url: 'https://www.rri.co.id/daerah/1554079/mitra-ternak-farm-kelola-ribuan-domba-berkualitas',
  },
  {
    type: 'video',
    title: 'CNN Indonesia Highlights Tuban Sheep Farming Innovation',
    summary: 'CNN Indonesia highlights sustainable sheep farming innovation in Tuban, East Java.',
    source: 'CNN Indonesia (YouTube)',
    date: 'May 20, 2025',
    thumbnail: '/images/media/cnn.webp',
    url: 'https://youtu.be/ym7HeTxi2oU',
  },
];
---

<PageLayout
  title="Media Coverage - Mitra Ternak Farm Tuban"
  description="News and media coverage of Mitra Ternak Farm Tuban. Featured on tvOne, iNews, CNN Indonesia and national media."
  heroTitle={t('mediapage.title')}
  heroSubtitle={t('mediapage.subtitle')}
>
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4">
      <!-- Tab Filters -->
      <div class="mb-12 flex flex-wrap justify-center gap-3">
        <button
          class="media-tab active rounded-full bg-primary px-6 py-2 font-body font-medium text-offwhite transition-colors"
          data-filter="all"
        >
          All
        </button>
        <button
          class="media-tab rounded-full bg-neutral px-6 py-2 font-body font-medium text-secondary transition-colors hover:bg-primary hover:text-offwhite"
          data-filter="news"
        >
          News
        </button>
        <button
          class="media-tab rounded-full bg-neutral px-6 py-2 font-body font-medium text-secondary transition-colors hover:bg-primary hover:text-offwhite"
          data-filter="video"
        >
          Video
        </button>
      </div>

      <!-- Media Grid -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" id="media-grid">
        {mediaItems.map((item, index) => (
          <ScrollReveal delay={index * 100}>
            <article class="media-card overflow-hidden rounded-2xl bg-white shadow-sm transition-shadow hover:shadow-lg" data-type={item.type}>
              <!-- Thumbnail -->
              <div class="relative h-48 overflow-hidden">
                <img src={item.thumbnail} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
                {item.type === 'video' && (
                  <div class="absolute inset-0 flex items-center justify-center bg-dark/30">
                    <div class="w-14 h-14 bg-primary/90 rounded-full flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-offwhite ml-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                )}
                <!-- Type Badge -->
                <span class:list={[
                  'absolute left-4 top-4 rounded-full px-3 py-1 text-xs font-body font-medium text-offwhite',
                  item.type === 'video' ? 'bg-accent' : 'bg-primary',
                ]}>
                  {item.type === 'video' ? 'Video' : 'News'}
                </span>
              </div>
              <!-- Content -->
              <div class="p-6">
                <h3 class="mb-2 font-heading text-lg text-secondary line-clamp-2">{item.title}</h3>
                <p class="mb-3 text-sm text-secondary/60 font-body line-clamp-3">{item.summary}</p>
                <div class="flex items-center justify-between text-sm font-body text-secondary/50 mb-3">
                  <span>{item.source}</span>
                  <span>{item.date}</span>
                </div>
                {item.url !== '#' && (
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-primary font-semibold hover:text-primary-dark transition-colors font-body">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
                    </svg>
                  </a>
                )}
              </div>
            </article>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();

  function initMediaTabs() {
    const tabs = document.querySelectorAll('.media-tab');
    const cards = document.querySelectorAll('.media-card');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const filter = (tab as HTMLElement).dataset.filter;

        // Update active tab
        tabs.forEach((t) => {
          t.classList.remove('active', 'bg-primary', 'text-offwhite');
          t.classList.add('bg-neutral', 'text-secondary');
        });
        tab.classList.add('active', 'bg-primary', 'text-offwhite');
        tab.classList.remove('bg-neutral', 'text-secondary');

        // Filter cards
        cards.forEach((card) => {
          const type = (card as HTMLElement).dataset.type;
          const wrapper = card.closest('[data-scroll-reveal]') as HTMLElement;
          if (filter === 'all' || type === filter) {
            if (wrapper) wrapper.style.display = '';
          } else {
            if (wrapper) wrapper.style.display = 'none';
          }
        });
      });
    });
  }

  initMediaTabs();
  document.addEventListener('astro:after-swap', initMediaTabs);
</script>
