---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const activities = [
  {
    icon: `<svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: t('valuechain.hulu.title'),
    summary: t('valuechain.hulu.desc'),
    href: '#',
  },
  {
    icon: `<svg class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: t('valuechain.penghubung.title'),
    summary: t('valuechain.penghubung.desc'),
    href: '#',
  },
  {
    icon: `<svg class="h-8 w-8 text-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
    title: t('valuechain.hilir.title'),
    summary: t('valuechain.hilir.desc'),
    href: '#',
  },
  {
    icon: `<svg class="h-8 w-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>`,
    title: t('valuechain.nilaitambah.title'),
    summary: t('valuechain.nilaitambah.desc'),
    href: '#',
  },
];
---

<PageLayout
  title={t('activities.title')}
  description={t('activities.subtitle')}
  heroTitle={t('activities.title')}
  heroSubtitle={t('activities.subtitle')}
>
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid gap-8 md:grid-cols-2">
        {activities.map((activity, index) => (
          <ScrollReveal delay={index * 100}>
            <div class:list={[
              'rounded-2xl p-8 transition-shadow hover:shadow-lg',
              index % 2 === 0 ? 'bg-offwhite' : 'bg-neutral',
            ]}>
              <div class="mb-4" set:html={activity.icon} />
              <h3 class="mb-3 font-heading text-2xl text-secondary">{activity.title}</h3>
              <p class="mb-6 font-body text-secondary/70 leading-relaxed">{activity.summary}</p>
              <a
                href={activity.href}
                class="inline-flex items-center gap-2 font-body font-medium text-primary transition-colors hover:text-primary/80"
              >
                Read More
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();
</script>
