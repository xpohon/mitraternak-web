---
import BaseLayout from './BaseLayout.astro';
import Button from '@/components/ui/Button.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  readTime?: string;
  lang?: 'id' | 'en';
}

const {
  title,
  description,
  date,
  author = 'Tim Mitra Ternak',
  readTime = '5 min',
  lang = 'id',
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString(lang === 'en' ? 'en-US' : 'id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} lang={lang}>
  <article>
    <!-- Article Hero -->
    <section class="pt-28 pb-12 bg-neutral">
      <div class="mx-auto max-w-3xl px-4">
        <a href="/blog" class="inline-flex items-center gap-1 text-sm text-primary font-body hover:text-primary-dark mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
          Kembali ke Blog
        </a>
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-secondary leading-tight">
          {title}
        </h1>
        <div class="mt-6 flex items-center gap-4 text-sm text-secondary/60 font-body">
          <span>{formattedDate}</span>
          <span>·</span>
          <span>{author}</span>
          <span>·</span>
          <span>{readTime} baca</span>
        </div>
      </div>
    </section>

    <!-- Article Content -->
    <section class="py-12">
      <div class="mx-auto max-w-3xl px-4 prose-article">
        <slot />
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 bg-neutral">
      <div class="mx-auto max-w-3xl px-4 text-center">
        <h2 class="font-heading text-2xl text-secondary mb-4">Tertarik bermitra dengan Mitra Ternak?</h2>
        <p class="font-body text-secondary/70 mb-6">Hubungi kami untuk informasi lebih lanjut tentang program kemitraan.</p>
        <Button href="https://wa.me/6285792671147" target="_blank" variant="primary" size="md">
          Hubungi via WhatsApp
        </Button>
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  .prose-article {
    font-family: var(--font-body);
    color: var(--color-secondary);
    line-height: 1.8;
    font-size: 1.05rem;
  }
  .prose-article h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-secondary);
  }
  .prose-article h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-secondary);
  }
  .prose-article p {
    margin-bottom: 1.25rem;
  }
  .prose-article ul, .prose-article ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-article li {
    margin-bottom: 0.5rem;
  }
  .prose-article strong {
    color: var(--color-secondary);
    font-weight: 700;
  }
  .prose-article a {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .prose-article blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-secondary);
    opacity: 0.8;
  }
</style>

<script>
  import { initScrollReveal } from '@/utils/animations';
  initScrollReveal();
</script>
