---
import { type Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { Phone, Mail, MapPin, Instagram, Youtube, Facebook } from '@lucide/astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const prefix = lang === 'en' ? '/en' : '';

const quickLinks = [
  { label: t('nav.home'), href: prefix || '/' },
  { label: t('nav.about'), href: `${prefix}/${lang === 'en' ? 'about' : 'tentang'}` },
  { label: t('nav.activities'), href: `${prefix}/${lang === 'en' ? 'activities' : 'kegiatan'}` },
  { label: t('nav.contact'), href: `${prefix}/${lang === 'en' ? 'contact' : 'kontak'}` },
];
---

<footer class="bg-secondary pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Col 1: Logo + Description -->
      <div>
        <a href={prefix || '/'} class="font-heading text-2xl text-primary">
          Mitra Ternak
        </a>
        <p class="mt-4 font-body text-sm leading-relaxed text-neutral/80">
          {t('footer.description')}
        </p>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h4 class="font-heading text-lg text-offwhite">
          {t('footer.quicklinks')}
        </h4>
        <ul class="mt-4 space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-neutral/70 transition-colors hover:text-primary"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contact Info -->
      <div>
        <h4 class="font-heading text-lg text-offwhite">
          {t('footer.contact')}
        </h4>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href="https://wa.me/6285792671147"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-body text-sm text-neutral/70 transition-colors hover:text-primary"
            >
              <Phone class="h-4 w-4 shrink-0" />
              <span>+62 857-9267-1147</span>
            </a>
          </li>
          <li>
            <a
              href="mailto:info@mitraternak.com"
              class="flex items-center gap-2 font-body text-sm text-neutral/70 transition-colors hover:text-primary"
            >
              <Mail class="h-4 w-4 shrink-0" />
              <span>info@mitraternak.com</span>
            </a>
          </li>
          <li>
            <div class="flex items-start gap-2 font-body text-sm text-neutral/70">
              <MapPin class="mt-0.5 h-4 w-4 shrink-0" />
              <span>{t('footer.location')}</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Col 4: Social Media -->
      <div>
        <h4 class="font-heading text-lg text-offwhite">
          {t('footer.social')}
        </h4>
        <div class="mt-4 flex items-center gap-4">
          <a
            href="https://instagram.com/mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="Instagram"
          >
            <Instagram class="h-5 w-5" />
          </a>
          <a
            href="https://youtube.com/@mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="YouTube"
          >
            <Youtube class="h-5 w-5" />
          </a>
          <a
            href="https://tiktok.com/@mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="TikTok"
          >
            <!-- TikTok icon (lucide doesn't have one, using a custom SVG) -->
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.72a8.19 8.19 0 004.76 1.52V6.79a4.84 4.84 0 01-1-.1z" />
            </svg>
          </a>
          <a
            href="https://facebook.com/mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="Facebook"
          >
            <Facebook class="h-5 w-5" />
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 border-t border-offwhite/10 pt-8 text-center">
      <p class="font-body text-sm text-neutral/50">
        {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
