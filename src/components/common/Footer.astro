---
import { type Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { Phone, Mail, MapPin, Instagram, Youtube, Facebook } from '@lucide/astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const prefix = lang === 'en' ? '/en' : '';

const quickLinks = [
  { label: t('nav.home'), href: prefix || '/' },
  { label: t('nav.about'), href: `${prefix}/${lang === 'en' ? 'about' : 'tentang'}` },
  { label: t('nav.activities'), href: `${prefix}/${lang === 'en' ? 'activities' : 'kegiatan'}` },
  { label: t('nav.contact'), href: `${prefix}/${lang === 'en' ? 'contact' : 'kontak'}` },
];
---

<footer class="bg-secondary pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Col 1: Logo + Description -->
      <div>
        <a href={prefix || '/'} class="inline-block">
          <img src="/images/logo/header.webp" alt="Mitra Ternak" class="h-10 w-auto brightness-110" />
        </a>
        <p class="mt-4 font-body text-sm leading-relaxed text-neutral/80">
          {t('footer.description')}
        </p>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h4 class="font-heading text-lg text-offwhite">
          {t('footer.quicklinks')}
        </h4>
        <ul class="mt-4 space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-neutral/70 transition-colors hover:text-primary"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contact Info -->
      <div>
        <h4 class="font-heading text-lg text-offwhite">
          {t('footer.contact')}
        </h4>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href="https://wa.me/6285792671147"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-body text-sm text-neutral/70 transition-colors hover:text-primary"
            >
              <Phone class="h-4 w-4 shrink-0" />
              <span>+62 857-9267-1147</span>
            </a>
          </li>
          <li>
            <a
              href="mailto:info@mitraternak.com"
              class="flex items-center gap-2 font-body text-sm text-neutral/70 transition-colors hover:text-primary"
            >
              <Mail class="h-4 w-4 shrink-0" />
              <span>info@mitraternak.com</span>
            </a>
          </li>
          <li>
            <div class="flex items-start gap-2 font-body text-sm text-neutral/70">
              <MapPin class="mt-0.5 h-4 w-4 shrink-0" />
              <span>{t('footer.location')}</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Col 4: Social Media -->
      <div>
        <h4 class="font-heading text-lg text-offwhite">
          {t('footer.social')}
        </h4>
        <div class="mt-4 flex items-center gap-4">
          <a
            href="https://instagram.com/mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="Instagram"
          >
            <Instagram class="h-5 w-5" />
          </a>
          <a
            href="https://youtube.com/@mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="YouTube"
          >
            <Youtube class="h-5 w-5" />
          </a>
          <a
            href="https://tiktok.com/@mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="TikTok"
          >
            <!-- TikTok icon (lucide doesn't have one, using a custom SVG) -->
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.72a8.19 8.19 0 004.76 1.52V6.79a4.84 4.84 0 01-1-.1z" />
            </svg>
          </a>
          <a
            href="https://facebook.com/mitraternak"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral/70 transition-colors hover:text-primary"
            aria-label="Facebook"
          >
            <Facebook class="h-5 w-5" />
          </a>
        </div>
      </div>
    </div>

    <!-- App Download Badges -->
    <div class="mt-10 flex flex-col items-center gap-4">
      <p class="font-body text-sm text-neutral/50">Download Aplikasi</p>
      <div class="flex items-center gap-3">
        <!-- Google Play Badge -->
        <a href="#" class="inline-block transition-opacity hover:opacity-80" aria-label="Download di Google Play">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 46" class="h-11 w-auto">
            <rect width="155" height="46" rx="5" fill="#fff"/>
            <path d="M8.3 22.6L20 15l3.1 1.8-11.6 6.7z" fill="#36a852"/>
            <path d="M8.3 22.6L20 30.3l3.1-1.8-11.6-6.7z" fill="#d63830"/>
            <path d="M23.1 16.8l3-1.7c.5-.3 1.1-.3 1.5 0l.1.1-4.6 2.6-3.1-1.8z" fill="#f9bc15"/>
            <path d="M23.1 28.5l3 1.7c.5.3 1.1.3 1.5 0l.1-.1-4.6-2.6-3.1 1.8z" fill="#5c85de"/>
            <path d="M8.3 22.6v-.2a.7.7 0 01.4-.6L20 15l3.1 1.8L11.5 23z" fill="#36a852"/>
            <path d="M8.3 22.6v.2a.7.7 0 00.4.6L20 30.3l3.1-1.8-11.6-6.7z" fill="#d63830"/>
            <text x="33" y="17" font-family="Arial,sans-serif" font-size="7" fill="#888" letter-spacing=".3">GET IT ON</text>
            <text x="33" y="31" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#333">Google Play</text>
          </svg>
        </a>
        <!-- App Store Badge -->
        <a href="#" class="inline-block transition-opacity hover:opacity-80" aria-label="Download di App Store">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 46" class="h-11 w-auto">
            <rect width="155" height="46" rx="5" fill="#fff"/>
            <g fill="#333">
              <path d="M22.7 22.5c0-2.2 1.2-3.5 2.6-4.6a3.6 3.6 0 00-2.8-1.5c-1.2-.1-2.4.7-3 .7s-1.6-.7-2.6-.7a3.8 3.8 0 00-3.2 2c-1.4 2.4-.4 5.9 1 7.8.7 1 1.4 2 2.5 2s1.4-.6 2.6-.6 1.6.6 2.6.6 1.7-1 2.4-1.9a8.5 8.5 0 001.1-2.2 3.4 3.4 0 01-2.2-3.6z"/>
              <path d="M20.7 15a3.4 3.4 0 00.8-2.5 3.5 3.5 0 00-2.3 1.2 3.3 3.3 0 00-.8 2.4c.9.1 1.7-.4 2.3-1.1z"/>
            </g>
            <text x="33" y="16" font-family="Arial,sans-serif" font-size="7" fill="#888" letter-spacing=".3">Download on the</text>
            <text x="33" y="31" font-family="Arial,sans-serif" font-size="14" font-weight="bold" fill="#333">App Store</text>
          </svg>
        </a>
      </div>
      <p class="font-body text-xs text-neutral/40 italic">Segera hadir</p>
    </div>

    <!-- Copyright -->
    <div class="mt-8 border-t border-offwhite/10 pt-8 text-center">
      <p class="font-body text-sm text-neutral/50">
        {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
