---
import { type Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import Button from '@/components/ui/Button.astro';
import { Menu, X } from '@lucide/astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const prefix = lang === 'en' ? '/en' : '';

const navLinks = [
  { label: t('nav.home'), href: prefix || '/' },
  { label: t('nav.about'), href: `${prefix}/${lang === 'en' ? 'about' : 'tentang'}` },
  { label: t('nav.activities'), href: `${prefix}/${lang === 'en' ? 'activities' : 'kegiatan'}` },
  { label: t('nav.contact'), href: `${prefix}/${lang === 'en' ? 'contact' : 'kontak'}` },
];

function isActive(href: string): boolean {
  const clean = currentPath.replace(/\/$/, '') || '/';
  const cleanHref = href.replace(/\/$/, '') || '/';
  return clean === cleanHref;
}
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo -->
      <a href={prefix || '/'} class="font-heading text-2xl text-primary">
        Mitra Ternak
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden items-center gap-8 lg:flex">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'font-body text-sm font-medium transition-colors hover:text-primary',
              isActive(link.href)
                ? 'text-primary border-b-2 border-primary pb-1'
                : 'text-secondary',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right: Language Switcher + CTA -->
      <div class="hidden items-center gap-4 lg:flex">
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
        <Button variant="primary" size="sm" href="https://wa.me/6285792671147">
          {t('nav.cta')}
        </Button>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="flex items-center justify-center lg:hidden"
        aria-label="Toggle menu"
      >
        <Menu id="menu-icon-open" class="h-6 w-6 text-secondary" />
        <X id="menu-icon-close" class="hidden h-6 w-6 text-secondary" />
      </button>
    </div>
  </div>

  <!-- Mobile Overlay Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 hidden flex-col items-center justify-center gap-8 bg-offwhite/95 backdrop-blur-md"
  >
    <button
      id="mobile-menu-close-btn"
      class="absolute top-6 right-6"
      aria-label="Close menu"
    >
      <X class="h-8 w-8 text-secondary" />
    </button>

    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'font-heading text-2xl transition-colors hover:text-primary',
          isActive(link.href) ? 'text-primary' : 'text-secondary',
        ]}
      >
        {link.label}
      </a>
    ))}

    <LanguageSwitcher lang={lang} currentPath={currentPath} />

    <Button variant="primary" size="md" href="https://wa.me/6285792671147">
      {t('nav.cta')}
    </Button>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuCloseBtn = document.getElementById('mobile-menu-close-btn');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  // Scroll behavior: transparent -> blurred bg
  function handleScroll() {
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add('backdrop-blur-md', 'bg-offwhite/90', 'shadow-sm');
    } else {
      navbar.classList.remove('backdrop-blur-md', 'bg-offwhite/90', 'shadow-sm');
    }
  }

  window.addEventListener('scroll', handleScroll);
  handleScroll();

  // Mobile menu toggle
  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    mobileMenu?.classList.add('flex');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('flex');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  mobileMenuBtn?.addEventListener('click', openMenu);
  mobileMenuCloseBtn?.addEventListener('click', closeMenu);
</script>
