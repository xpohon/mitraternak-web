---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  dark?: boolean;
}

const { title, subtitle, align = 'center', dark = false } = Astro.props;
---

<div
  class:list={[
    'mb-12',
    align === 'center' ? 'text-center' : 'text-left',
  ]}
>
  <h2
    class:list={[
      'font-heading text-3xl md:text-4xl lg:text-5xl',
      dark ? 'text-offwhite' : 'text-secondary',
    ]}
  >
    {title}
  </h2>

  <div
    class:list={[
      'mt-4 h-1 w-16 rounded bg-primary',
      align === 'center' ? 'mx-auto' : '',
    ]}
  ></div>

  {subtitle && (
    <p
      class:list={[
        'mt-4 font-body text-lg',
        dark ? 'text-offwhite/70' : 'text-secondary/70',
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
