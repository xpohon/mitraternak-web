---
import SectionHeading from '@/components/common/SectionHeading.astro';
import { useTranslations } from '@/i18n/utils';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';
import { getCollection } from 'astro:content';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url) || 'id';
const t = useTranslations(lang);

// Get media from content collection
const mediaCollection = await getCollection('media', ({ data }) => data.published);
const allMedia = mediaCollection
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Get unique sources for trust bar
const mediaSources = [...new Set(allMedia.map((m) => m.data.source.replace(' (YouTube)', '')))];

// Get top 4 for featured cards
const featuredMedia = allMedia.slice(0, 4).map((item) => ({
  title: lang === 'en' ? item.data.title_en : item.data.title_id,
  source: item.data.source,
  date: new Date(item.data.date).toLocaleDateString(lang === 'en' ? 'en-US' : 'id-ID', { day: 'numeric', month: 'short', year: 'numeric' }),
  type: item.data.type,
  url: item.data.url,
}));
---

<section class="py-20 lg:py-28 bg-neutral" id="media">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <SectionHeading title={t('media.title')} subtitle={t('media.subtitle')} />

    <!-- Media Logo Trust Bar -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-8 md:gap-12">
      {mediaSources.map((source) => (
        <div class="flex items-center gap-2 opacity-50 hover:opacity-100 transition-opacity duration-300">
          <span class="font-heading text-lg md:text-xl text-secondary/80">{source}</span>
        </div>
      ))}
    </div>

    <div class="mt-4 w-full h-px bg-secondary/10"></div>

    <!-- Featured Articles Grid -->
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {featuredMedia.map((item) => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block rounded-xl bg-offwhite p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 border border-secondary/5"
        >
          <div class="flex items-center gap-2 mb-3">
            <span class:list={[
              'w-2 h-2 rounded-full flex-shrink-0',
              item.type === 'video' ? 'bg-accent' : 'bg-primary',
            ]}></span>
            <span class="text-xs font-body text-secondary/50 uppercase tracking-wider">{item.source}</span>
          </div>

          <h3 class="font-heading text-base text-secondary leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-300">
            {item.title}
          </h3>

          <div class="mt-4 flex items-center justify-between">
            <span class="text-xs font-body text-secondary/40">{item.date}</span>
            <span class="text-xs font-body text-primary font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center gap-1">
              {item.type === 'video' ? (lang === 'en' ? 'Watch' : 'Tonton') : (lang === 'en' ? 'Read' : 'Baca')}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- View All Link -->
    <div class="mt-8 text-center">
      <a
        href={lang === 'en' ? '/en/media' : '/media'}
        class="inline-flex items-center gap-2 text-sm font-body font-semibold text-primary hover:text-primary-dark transition-colors"
      >
        {lang === 'en' ? 'View all media coverage' : 'Lihat semua liputan media'}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
