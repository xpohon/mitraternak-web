---
import Button from '@/components/ui/Button.astro';
import ScrollReveal from '@/components/common/ScrollReveal.astro';
import { useTranslations } from '@/i18n/utils';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url) || 'id';
const t = useTranslations(lang);
---

<section class="py-20 lg:py-28 bg-offwhite" id="about">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div data-scroll-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider font-body">
          {t('about.subtitle')}
        </span>
        <h2 class="mt-3 font-heading text-3xl md:text-4xl lg:text-5xl text-secondary">
          {t('about.title')}
        </h2>
        <div class="mt-2 w-16 h-1 bg-primary rounded-full"></div>
        <p class="mt-6 text-lg text-secondary/75 leading-relaxed font-body">
          {t('about.description')}
        </p>
        <div class="mt-8">
          <Button variant="primary" size="md" href={lang === 'en' ? '/en/about' : '/tentang'}>
            {t('about.readmore')} →
          </Button>
        </div>
      </div>

      <!-- Image with parallax -->
      <div class="relative" data-scroll-reveal data-delay="200">
        <div class="relative overflow-hidden rounded-2xl shadow-xl" data-parallax-image>
          <!-- Placeholder image -->
          <div class="aspect-[4/3] bg-gradient-to-br from-warm/30 to-primary/20 flex items-center justify-center">
            <div class="text-center text-secondary/40">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a1.5 1.5 0 001.5-1.5V4.5a1.5 1.5 0 00-1.5-1.5H3.75a1.5 1.5 0 00-1.5 1.5v15a1.5 1.5 0 001.5 1.5z" />
              </svg>
              <p class="text-sm font-body">Photo placeholder</p>
            </div>
          </div>
        </div>
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-primary/10 rounded-2xl -z-10"></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 bg-accent/10 rounded-2xl -z-10"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('[data-parallax-image]').forEach((el) => {
      gsap.to(el, {
        y: -30,
        ease: 'none',
        scrollTrigger: {
          trigger: el.parentElement,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        },
      });
    });
  }
</script>
