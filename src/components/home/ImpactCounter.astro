---
interface Props {
  value: number;
  suffix: string;
  label: string;
  icon: string;
  delay?: number;
}

const { value, suffix, label, icon, delay = 0 } = Astro.props;
---

<div
  class="bg-offwhite rounded-2xl p-6 lg:p-8 text-center shadow-sm hover:shadow-md transition-shadow duration-300"
  data-scroll-reveal
  data-delay={delay.toString()}
>
  <span class="text-4xl mb-4 block">{icon}</span>
  <div class="flex items-baseline justify-center gap-1">
    <span
      class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary font-body"
      data-counter={value.toString()}
    >
      0
    </span>
    <span class="text-2xl md:text-3xl font-bold text-primary">{suffix}</span>
  </div>
  <p class="mt-3 text-sm md:text-base text-secondary/70 font-body">{label}</p>
</div>

<script>
  import { initCounterAnimation } from '@/utils/animations';
  initCounterAnimation();
</script>
