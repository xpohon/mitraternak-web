---
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';

interface Props {
  slug: string;
  name: string;
  tagline: string;
  image: string;
  color: string;
  lang: Lang;
  delay?: number;
}

const { slug, name, tagline, image, color, lang, delay = 0 } = Astro.props;
const t = useTranslations(lang);
const href = lang === 'en' ? `/en/products/${slug}` : `/produk/${slug}`;
---

<a
  href={href}
  class="group block rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-500 hover:-translate-y-2"
  data-scroll-reveal
  data-delay={delay.toString()}
>
  <div class="relative aspect-[3/4] overflow-hidden">
    <!-- Placeholder background -->
    <div class={`absolute inset-0 bg-gradient-to-b ${color}`}>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-offwhite/30">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a1.5 1.5 0 001.5-1.5V4.5a1.5 1.5 0 00-1.5-1.5H3.75a1.5 1.5 0 00-1.5 1.5v15a1.5 1.5 0 001.5 1.5z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Content overlay -->
    <div class="absolute inset-0 flex flex-col justify-end p-6 bg-gradient-to-t from-dark/80 via-dark/20 to-transparent">
      <h3 class="font-heading text-2xl text-offwhite group-hover:text-warm transition-colors duration-300">
        {name}
      </h3>
      <p class="mt-1 text-sm text-offwhite/70 font-body">{tagline}</p>

      <!-- Hover reveal -->
      <div class="mt-4 flex items-center gap-2 text-warm opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
        <span class="text-sm font-semibold font-body">{t('products.viewmore')}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </div>
    </div>
  </div>
</a>
